generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  passwordHash  String
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AutoReplyConfig {
  id              String   @id @default(uuid())
  userId          String   @unique
  enabled         Boolean  @default(false)
  message         String   @default("Hi! I can't take your call right now. Please drop me a text and I'll get back to you as soon as I'm free.")
  signature       String   @default("— AI Assistant")
  // Don't auto-reply to the same number more than once per this many minutes.
  cooldownMinutes Int      @default(60)
  // Auto post-call recap: text a summary to the owner after a recorded call.
  recapEnabled    Boolean  @default(false)
  recapNumber     String   @default("") // owner's own number (self-recap target)
  recapMode       String   @default("smart") // smart | always_send | always_ask
  updatedAt       DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Call {
  id             String   @id @default(uuid())
  contactName    String?
  phoneNumber    String
  direction      String // incoming | outgoing | missed | rejected
  durationSec    Int      @default(0)
  occurredAt     DateTime
  recordingUrl   String?
  sourceFileName String?
  transcript     String?
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([phoneNumber, occurredAt]) // dedupe re-synced calls
  @@index([occurredAt])
}

model SmsTxn {
  id          String    @id @default(uuid())
  type        String // debit | credit | payment_due | spam | unknown
  amountMinor Int?
  currency    String    @default("INR")
  merchant    String?
  source      String?
  category    String?
  rawBody     String
  sender      String
  receivedAt  DateTime
  dueAt       DateTime?
  dedupeKey   String    @unique
  createdAt   DateTime  @default(now())

  @@index([receivedAt])
  @@index([type])
}

model MediaAsset {
  id             String   @id @default(uuid())
  type           String // photo | video
  storageKey     String // object key in the media bucket
  sourceFileName String
  sizeBytes      Int      @default(0)
  capturedAt     DateTime
  dedupeKey      String   @unique // stable per device file, dedupes re-syncs
  createdAt      DateTime @default(now())

  @@index([capturedAt])
  @@index([type])
}

model LocationPoint {
  id        String   @id @default(uuid())
  lat       Float
  lng       Float
  recordedAt DateTime
  dedupeKey String   @unique // device-stable, dedupes re-synced points
  createdAt DateTime @default(now())

  @@index([recordedAt])
}
