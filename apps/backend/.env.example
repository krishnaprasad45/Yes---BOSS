# Postgres (docker compose default)
DATABASE_URL="postgresql://yesboss:yesboss@localhost:5432/yesboss?schema=public"

# Auth
JWT_SECRET="change-me-long-random-string"
JWT_ACCESS_TTL="15m"

# Single admin user (used by prisma:seed)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_NAME="Boss"

# Server
PORT=4000

# MinIO (file storage — wired in Phase 2)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="yesboss"
MINIO_SECRET_KEY="yesboss-secret"
MINIO_BUCKET="call-recordings"

# Post-call recap (Phase 4). Leave blank to disable that half of the pipeline.
# Transcription = Whisper (any OpenAI-compatible endpoint); summary = an
# OpenAI-compatible chat endpoint (RECAP_BASE_URL) or Anthropic Claude.
#
# --- Zero-cost setup: Groq free tier (one key powers both) ---------------
# Get a free key at https://console.groq.com/keys, then:
#   RECAP_BASE_URL="https://api.groq.com/openai/v1"
#   RECAP_API_KEY="gsk_..."
#   RECAP_MODEL="llama-3.3-70b-versatile"
#   WHISPER_BASE_URL="https://api.groq.com/openai/v1"
#   WHISPER_API_KEY="gsk_..."          # same Groq key
#   WHISPER_MODEL="whisper-large-v3"
#
# Summary: OpenAI-compatible (Groq/Ollama/etc.). Preferred when RECAP_BASE_URL set.
RECAP_BASE_URL=""
RECAP_API_KEY=""
RECAP_MODEL="llama-3.3-70b-versatile"
# Summary fallback: Anthropic Claude (used only when RECAP_BASE_URL is blank).
ANTHROPIC_API_KEY=""
# Transcription: OpenAI-compatible Whisper endpoint.
WHISPER_API_KEY=""
WHISPER_BASE_URL="https://api.groq.com/openai/v1"
WHISPER_MODEL="whisper-large-v3"
