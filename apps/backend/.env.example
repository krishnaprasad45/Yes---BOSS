# Postgres (docker compose default)
DATABASE_URL="postgresql://yesboss:yesboss@localhost:5432/yesboss?schema=public"

# Auth
JWT_SECRET="change-me-long-random-string"
JWT_ACCESS_TTL="15m"

# Single admin user (used by prisma:seed)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_NAME="Boss"

# Server
PORT=4000

# MinIO (file storage — wired in Phase 2)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="yesboss"
MINIO_SECRET_KEY="yesboss-secret"
MINIO_BUCKET="call-recordings"

# Post-call recap (Phase 4). Leave blank to disable that half of the pipeline.
# Anthropic powers the LLM summary; Whisper (OpenAI-compatible) powers transcription.
ANTHROPIC_API_KEY=""
RECAP_MODEL="claude-opus-4-8"
WHISPER_API_KEY=""
WHISPER_BASE_URL="https://api.openai.com/v1"
WHISPER_MODEL="whisper-1"
