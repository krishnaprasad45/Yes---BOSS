# Production env for the AWS deploy. Copy to apps/backend/.env.production and fill
# in real values. NEVER commit the filled file (it's gitignored).

# --- Postgres (compose creates this DB; host = the "postgres" service) ---------
POSTGRES_USER="yesboss"
POSTGRES_PASSWORD="CHANGE-ME-strong-db-password"
POSTGRES_DB="yesboss"
DATABASE_URL="postgresql://yesboss:CHANGE-ME-strong-db-password@postgres:5432/yesboss?schema=public"

# --- Auth ----------------------------------------------------------------------
# Generate: openssl rand -base64 48
JWT_SECRET="CHANGE-ME-long-random-string"
JWT_ACCESS_TTL="15m"
DEVICE_TOKEN_TTL="90d"

# --- Admin user (prisma:seed) --------------------------------------------------
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="CHANGE-ME-strong-admin-password"
ADMIN_NAME="Boss"

# --- Server --------------------------------------------------------------------
PORT=4000

# --- Object storage: AWS S3 (free tier 5GB) ------------------------------------
# Same client also works with Backblaze B2 (10GB free forever) — just swap the
# endpoint/region/keys, no code change.
#   S3:  s3.<region>.amazonaws.com
#   B2:  s3.<region>.backblazeb2.com
MINIO_ENDPOINT="s3.ap-south-1.amazonaws.com"
MINIO_PORT=443
MINIO_USE_SSL="true"
MINIO_REGION="ap-south-1"
MINIO_ACCESS_KEY="AWS_ACCESS_KEY_ID"
MINIO_SECRET_KEY="AWS_SECRET_ACCESS_KEY"
MINIO_BUCKET="yesboss-recordings"

# --- Post-call recap: Groq free tier (one key, both halves) --------------------
RECAP_BASE_URL="https://api.groq.com/openai/v1"
RECAP_API_KEY="gsk_..."
RECAP_MODEL="llama-3.3-70b-versatile"
WHISPER_BASE_URL="https://api.groq.com/openai/v1"
WHISPER_API_KEY="gsk_..."
WHISPER_MODEL="whisper-large-v3"
# Optional: pin transcription language for short/noisy clips, e.g. "hi" or "en".
# WHISPER_LANGUAGE="hi"
