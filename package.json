{
  "name": "yes-boss",
  "private": true,
  "version": "0.1.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "**/react-native",
      "**/react-native/**",
      "**/@react-native/**",
      "**/@react-native-community/**"
    ]
  },
  "scripts": {
    "backend": "yarn workspace @yes-boss/backend start:dev",
    "mobile": "yarn workspace @yes-boss/mobile start",
    "android": "yarn workspace @yes-boss/mobile android",
    "shared:build": "yarn workspace @yes-boss/shared build",
    "typecheck": "yarn workspace @yes-boss/shared typecheck && yarn workspace @yes-boss/backend typecheck && yarn workspace @yes-boss/mobile typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev:swagger": "yarn workspace @yes-boss/swagger-ui dev",
    "swagger:export": "node apps/swagger-ui/export-specs.js"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
